# .gitignore for C# and .NET projects

# Visual Studio Code
.vscode/
*.code-workspace

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio cache/options
.vs/

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Dependencies
obj/
bin/
*.dll
*.pdb
*.cache

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/
.packages/
*.packages.config

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.idea/
*.iml
*.iws
*.ipr

# Environment
.env
.env.local

# Node modules (if using npm for frontend tools)
node_modules/
npm-debug.log
